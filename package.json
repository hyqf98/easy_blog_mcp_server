{
  "name": "@hyqf98/mcp-blog-server",
  "version": "1.0.3",
  "description": "MCP Server for publishing blogs to CSDN, Juejin, Cnblog",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp_blog_server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js"
  },
