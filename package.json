  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.0",
    "cheerio": "^1.2.0",
    "form-data": "^4.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
