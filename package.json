    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
