{
  "name": "@hyqf98/easy_blog_mcp_server",
  "version": "1.0.0",
  "description": "MCP Server for publishing blogs to CSDN, Juejin, Cnblog",
  "type": "module",
  "bin": {
    "easy_blog_mcp_server": "dist/index.js"
  },
  "scripts": {
